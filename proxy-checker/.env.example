# Server Configuration
PORT=8080

# Database
DB_PATH=data/proxy.db

# Authentication (CHANGE THESE BEFORE PRODUCTION!)
SESSION_SECRET=change-this-to-32-byte-secret-minimum
ADMIN_PASSWORD=change-this-to-secure-password

# Proxy Checker Settings
CHECK_INTERVAL=20m
WORKER_COUNT=100
CHECK_TIMEOUT=10s

# Test URLs (comma-separated, used in fallback order)
TEST_URLS=http://httpbin.org/ip,https://api.ipify.org?format=json,https://cloudflare.com/cdn-cgi/trace
